<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="30"
             x:Class="Powerplant.Controls.ToolsSettings.DrawRectangleToolSettings">
    <StackPanel Orientation="Horizontal" Spacing="5">
        <ToggleButton x:Name="OutlineRectOptionButton" Click="OutlineRectOptionButton_OnClick">Outlined</ToggleButton>
        <ToggleButton x:Name="FillRectOptionButton" Click="FillRectOptionButton_OnClick">Filled</ToggleButton>
        <Border Background="#55000000" Width="1" Height="15"></Border>
        <TextBlock VerticalAlignment="Center">Stroke Size</TextBlock>
        <NumericUpDown x:Name="StrokeSizeSpin" Width="110" Minimum="1" ValueChanged="StrokeSizeSpin_OnValueChanged"></NumericUpDown>
    </StackPanel>
</UserControl>
