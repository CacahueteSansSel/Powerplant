<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:windows="clr-namespace:Powerplant.Windows"
        mc:Ignorable="d" Width="300" Height="400"
        x:Class="Powerplant.Windows.ResizeViewportWindow"
        Title="Resize Viewport"
        Loaded="Control_OnLoaded"
        x:DataType="windows:ResizeViewportWindow+Data">
    <DockPanel Margin="10">
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10">
            <Button Click="CancelButtonClicked">Cancel</Button>
            <Button Click="CreateTextureButtonClicked" IsDefault="True" Classes="primary">Resize</Button>
        </StackPanel>
        <StackPanel Spacing="10">
            <TextBlock Classes="title" Margin="0 0 0 10">Resize Viewport</TextBlock>
            <DockPanel>
                <NumericUpDown x:Name="WidthBox" DockPanel.Dock="Right" Width="170" Value="{Binding Width}"></NumericUpDown>
                <TextBlock VerticalAlignment="Center">New width</TextBlock>
            </DockPanel>
            <DockPanel>
                <NumericUpDown DockPanel.Dock="Right" Width="170" Value="{Binding Height}"></NumericUpDown>
                <TextBlock VerticalAlignment="Center">New height</TextBlock>
            </DockPanel>
            <DockPanel>
                <Grid DockPanel.Dock="Right" Width="100" Height="100" RowSpacing="2" ColumnSpacing="2"
                      ColumnDefinitions="*,*,*" RowDefinitions="*,*,*">
                    <ToggleButton x:Name="BtnTL" Grid.Column="0" Grid.Row="0" Click="PlacementButtonClicked" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"></ToggleButton>
                    <ToggleButton x:Name="BtnTM" Grid.Column="1" Grid.Row="0" Click="PlacementButtonClicked" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"></ToggleButton>
                    <ToggleButton x:Name="BtnTR" Grid.Column="2" Grid.Row="0" Click="PlacementButtonClicked" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"></ToggleButton>
                    <ToggleButton x:Name="BtnML" Grid.Column="0" Grid.Row="1" Click="PlacementButtonClicked" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"></ToggleButton>
                    <ToggleButton x:Name="BtnMM" Grid.Column="1" Grid.Row="1" Click="PlacementButtonClicked" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"></ToggleButton>
                    <ToggleButton x:Name="BtnMR" Grid.Column="2" Grid.Row="1" Click="PlacementButtonClicked" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"></ToggleButton>
                    <ToggleButton x:Name="BtnBL" Grid.Column="0" Grid.Row="2" Click="PlacementButtonClicked" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"></ToggleButton>
                    <ToggleButton x:Name="BtnBM" Grid.Column="1" Grid.Row="2" Click="PlacementButtonClicked" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"></ToggleButton>
                    <ToggleButton x:Name="BtnBR" Grid.Column="2" Grid.Row="2" Click="PlacementButtonClicked" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"></ToggleButton>
                </Grid>
                <TextBlock VerticalAlignment="Top">
                    Existing Content
                </TextBlock>
            </DockPanel>
        </StackPanel>
    </DockPanel>
</Window>
