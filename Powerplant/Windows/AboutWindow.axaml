<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" Width="400" Height="500"
        x:Class="Powerplant.Windows.AboutWindow"
        Title="About Powerplant">
    <DockPanel Margin="10">
        <StackPanel Orientation="Vertical" Spacing="4" DockPanel.Dock="Top">
            <Svg Path="/Resources/logos/powerplant.svg"></Svg>
            <TextBlock TextAlignment="Center" FontWeight="Bold">Powerplant - The paint.net killer</TextBlock>
            <TextBlock TextAlignment="Center" FontStyle="Italic" Opacity="0.5" FontSize="11">In memory of my old dead laptop, the "powerplant"</TextBlock>
            
            <TextBlock TextAlignment="Center" Margin="0 10 0 20">Lightweight cross-platform image editor</TextBlock>
            <TextBlock TextAlignment="Center">Copyright © Cacahuète Dev and Contributors, 2026</TextBlock>
        </StackPanel>
        <StackPanel DockPanel.Dock="Bottom">
            <Button HorizontalAlignment="Right" Click="Button_OnClick">Close</Button>
        </StackPanel>
        <Panel></Panel>
    </DockPanel>
</Window>
